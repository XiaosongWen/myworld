# ==========================================
# Shared Infrastructure Settings
# ==========================================
POSTGRES_CONTAINER_NAME=mynest-postgres
POSTGRES_USER=mynest
POSTGRES_PASSWORD=mynest
POSTGRES_DB=mynest
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=./data/postgres

REDIS_CONTAINER_NAME=mynest-redis
REDIS_PORT=6379
REDIS_DATA_DIR=./data/redis

RESTART_POLICY=unless-stopped

# ==========================================
# Application Environment Variable Mappings
# ==========================================
# NOTE: The variables below are shared by stage and prod compose files.
# Copy this file to .env.stage or .env.prod and customize per environment.
# Then run: docker compose --env-file .env.stage -f docker-compose.infra.yml -f docker-compose.stage.yml up -d
#
# See README.md for full per-environment examples.

# -- Staging example (active by default) --
APP_IMAGE=tomaswen/mynest:stage
APP_CONTAINER_NAME=mynest-stage-app
APP_PORT=8001

DATABASE_URL=postgresql+asyncpg://mynest:mynest@postgres:5432/mynest_stage
REDIS_URL=redis://redis:6379
STORAGE_PATH=/app/storage
STORAGE_DATA_DIR=./data/stage/storage

# -- Production (uncomment and set PROD_APP_TAG to switch) --
# PROD_APP_TAG=v1.0.0
# APP_IMAGE=tomaswen/mynest:${PROD_APP_TAG}
# APP_CONTAINER_NAME=mynest-prod-app
# APP_PORT=8000
# DATABASE_URL=postgresql+asyncpg://mynest:mynest@postgres:5432/mynest_prod
# STORAGE_DATA_DIR=./data/prod/storage
# CPU_LIMIT=2.0
# MEMORY_LIMIT=2048M
# RESTART_POLICY=always
