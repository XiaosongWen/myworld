# PostgreSQL Infrastructure Settings (Shared Postgres Instance)
POSTGRES_CONTAINER_NAME=myworld-postgres
POSTGRES_USER=myworld
POSTGRES_PASSWORD=myworld
POSTGRES_DB=myworld
POSTGRES_PORT=5432
POSTGRES_DATA_DIR=./data/postgres

# Redis Infrastructure Settings
REDIS_CONTAINER_NAME=myworld-redis
REDIS_PORT=6379
REDIS_DATA_DIR=./data/redis

# Global Infrastructure Restart Policy
RESTART_POLICY=unless-stopped

# Application Environment Specific Variables
# (Used when deploying stage or prod containers against the shared PostgreSQL & Redis instance)

# Database URLs for different environments (same Postgres host, different databases)
DEV_DATABASE_URL=postgresql+asyncpg://myworld:myworld@postgres:5432/myworld
STAGE_DATABASE_URL=postgresql+asyncpg://myworld:myworld@postgres:5432/myworld_stage
PROD_DATABASE_URL=postgresql+asyncpg://myworld:myworld@postgres:5432/myworld_prod

# Stage Application Deployment Settings
STAGE_APP_IMAGE=tomaswen/mynest:latest
STAGE_APP_CONTAINER_NAME=mynest-stage-app
STAGE_APP_PORT=8001
STAGE_STORAGE_DATA_DIR=./data/stage/storage

# Prod Application Deployment Settings
PROD_APP_TAG=v1.0.0
PROD_APP_IMAGE=tomaswen/mynest:${PROD_APP_TAG}
PROD_APP_CONTAINER_NAME=mynest-prod-app
PROD_APP_PORT=8000
PROD_STORAGE_DATA_DIR=./data/prod/storage
PROD_CPU_LIMIT=2.0
PROD_MEMORY_LIMIT=2048M

# Common App Settings
REDIS_URL=redis://redis:6379
STORAGE_PATH=/app/storage
